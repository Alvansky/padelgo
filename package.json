{
  "name": "padelgo",
  "version": "1.0.0",
  "description": "PadelGo - Padel Court Booking Platform",
  "scripts": {
    "build:css": "npx tailwindcss -i assets/css/main.css -o static/css/styles.css --minify",
    "build": "hugo --gc --minify",
    "dev": "npx tailwindcss -i assets/css/main.css -o static/css/styles.css --watch",
    "build:all": "npm run build:css && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alvansky/padelgo.git"
  },
  "keywords": ["padel", "booking", "sports"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Alvansky/padelgo/issues"
  },
  "homepage": "https://github.com/Alvansky/padelgo#readme",
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19"
  }
}
